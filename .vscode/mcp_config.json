{
    "mcpServers": {
        "winnipeg-assistant": {
            "command": "uv",
            "args": [
                "run",
                "--script",
                "/Users/nhan/wpg-city-mcp/server.py"
            ],
            "env": {
                "TRANSIT_API_KEY": "REDACTED_API_KEY",
                "PYTHONUTF8": "1"
            }
        },
        "github-mcp-server": {
            "type": "http",
            "url": "https://api.githubcopilot.com/mcp/",
            "headers": {
                "Authorization": "${input:Authorization}"
            }
        }
    },
    "inputs": [
        {
            "id": "Authorization",
            "type": "promptString",
            "description": "Authentication token (PAT or App token)",
            "password": true
        }
    ]
}